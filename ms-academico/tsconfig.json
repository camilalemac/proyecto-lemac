{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext", 
    "outDir": "./dist",
    "rootDir": "./",
    /* Eliminamos 'baseUrl' y ajustamos 'paths' para el nuevo estándar */
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "removeComments": true,
    /* Silenciamos las alertas de desuso de TS 7.0 por si acaso */
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*", "app.ts", "server.ts"],
  "exclude": ["node_modules", "dist", "wallet", "**/*.test.ts"]
}