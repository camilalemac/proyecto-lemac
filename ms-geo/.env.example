# ====================================================
# MICROSERVICIO MS-GEO - LEMAC DATALAB (Manual v6)
# ====================================================
NODE_ENV=development
PORT=3000

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=ms_geo_user
DB_PASSWORD=
DB_NAME=MS_GEO

# Seguridad y Criptografía (Wallet ISO 27001)
DB_WALLET_DIR=./wallet
TNS_ADMIN=./wallet

# Auth0 (A.9 Control de Acceso)
AUTH0_ISSUER_URL=https://<tu-dominio>.auth0.com/
AUTH0_AUDIENCE=<tu-api-identifier>

# Observabilidad
LOG_LEVEL=info